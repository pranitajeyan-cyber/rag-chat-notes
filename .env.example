# LLM Provider: gemini, groq, or ollama
LLM_PROVIDER=gemini

# For Google Gemini (free): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# For Groq (free): https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# For local Ollama: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embedding model (runs locally, free)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=4
